#!/bin/bash
#
# pre-push hook for report_courseradar
#
# Runs PHPUnit tests locally before pushing to any branch other than
# main and dev (those are covered by GitHub Actions CI).
#
# Activate once per clone:
#   make setup
# or manually:
#   git config core.hooksPath .githooks

# Read push info from stdin.
while read -r local_ref local_sha remote_ref remote_sha; do

    branch="${remote_ref#refs/heads/}"

    # main and dev are tested by CI — skip locally.
    if [ "$branch" = "main" ] || [ "$branch" = "dev" ]; then
        exit 0
    fi

    echo "▶ Pre-push: running PHPUnit for report_courseradar (branch: $branch)..."

    # The plugin root is the repo root; Moodle root is two levels up.
    PLUGIN_DIR="$(pwd)"
    MOODLE_ROOT="$(cd "$PLUGIN_DIR/../.." && pwd)"
    PHPUNIT="$MOODLE_ROOT/vendor/bin/phpunit"

    if [ ! -f "$PHPUNIT" ]; then
        echo ""
        echo "  ERROR: PHPUnit not initialised in Moodle."
        echo "  Run once: cd $MOODLE_ROOT && php admin/tool/phpunit/cli/init.php"
        echo ""
        exit 1
    fi

    if [ ! -f "$MOODLE_ROOT/phpunit.xml" ]; then
        echo ""
        echo "  ERROR: phpunit.xml not found."
        echo "  Run once: cd $MOODLE_ROOT && php admin/tool/phpunit/cli/init.php"
        echo ""
        exit 1
    fi

    cd "$MOODLE_ROOT" || exit 1

    "$PHPUNIT" --testsuite report_courseradar_testsuite
    EXIT_CODE=$?

    if [ $EXIT_CODE -ne 0 ]; then
        echo ""
        echo "  Tests FAILED — push aborted."
        echo ""
        exit 1
    fi

    echo "  Tests passed."
done

exit 0
